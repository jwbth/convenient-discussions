{
	"name": "convenient-discussions",
	"version": "0.0.0",
	"description": "A JavaScript shell for wiki talk pages.",
	"homepage": "https://commons.wikimedia.org/wiki/User:Jack_who_built_the_house/Convenient_Discussions",
	"bugs": {
		"url": "https://phabricator.wikimedia.org/tag/convenient-discussions/"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jwbth/convenient-discussions.git"
	},
	"license": "MIT",
	"author": "Jack who built the house",
	"type": "module",
	"sideEffects": [
		"./src/loader/convenientDiscussions.js",
		"./src/loader/convenientDiscussions.loader.js",
		"./src/loader/convenientDiscussions.utils.js",
		"./src/loader/convenientDiscussions.debug.js",
		"./src/shared/polyfills.js",
		"./src/worker/worker.js",
		"./src/worker/extendDomhandler.js",
		"./dist/convenientDiscussions-i18n/en.js"
	],
	"browser": "src/loader/startup.js",
	"scripts": {
		"build": "node build-wrapper.js",
		"build:staging": "node build-wrapper.js --mode staging",
		"build:single": "node build-wrapper.js --mode single",
		"configs": "node build-configs.js",
		"dev": "vite",
		"deploy": "node --unhandled-rejections=strict deploy.js",
		"format": "prettier --write .",
		"i18n": "node build-i18n.js",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"postinstall": "patch-package",
		"preview": "vite preview",
		"single": "node build-wrapper.js --mode single",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:regenerate": "cross-env REGENERATE=1 vitest run tests/worker-regenerate-test-cases.test.js",
		"test:browser": "playwright test",
		"test:browser:auth": "playwright test test-wikipedia-auth.spec.js",
		"test:browser:edit": "cross-env TEST_EDIT=1 playwright test",
		"test:browser:headed": "playwright test --headed",
		"vite": "vite build"
	},
	"browserslist": [
		"> 1%"
	],
	"dependencies": {
		"date-fns": "^4.1.0",
		"date-fns-tz": "^3.2.0",
		"dayjs": "^1.11.20",
		"htmlparser2": "^12.0.0",
		"locutus": "^3.0.34",
		"lz-string": "^1.5.0",
		"mwn": "^3.0.1",
		"oojs": "^7.0.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.32.0",
		"@playwright/test": "^1.59.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/jquery": "^3.5.34",
		"@types/jqueryui": "^1.12.24",
		"@types/oojs": "^7.0.7",
		"@types/oojs-ui": "^0.49.4",
		"@types/prompts": "^2.4.9",
		"ajv": "^6.14.0",
		"chalk": "^5.6.2",
		"codemirror": "^6.0.2",
		"core-js": "^3.49.0",
		"cross-env": "^7.0.3",
		"dompurify": "^3.4.0",
		"dotenv": "^17.4.2",
		"eslint": "^9.39.4",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-es-x": "^9.6.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "^60.8.3",
		"eslint-plugin-no-one-time-vars": "^2.7.0",
		"eslint-plugin-unicorn": "^60.0.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"https-proxy-agent": "^9.0.0",
		"jsdom": "^27.4.0",
		"json5": "^2.2.3",
		"less": "^4.6.4",
		"node-fetch": "^3.3.2",
		"patch-package": "^8.0.1",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prompts": "^2.4.2",
		"rimraf": "^6.1.3",
		"tar": "^7.5.13",
		"terser": "^5.46.1",
		"types-mediawiki": "^1.10.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.9",
		"vite-plugin-banner": "^0.8.1",
		"vitest": "^4.1.4",
		"yargs": "^18.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
