{
	"name": "convenient-discussions",
	"version": "0.0.0",
	"description": "A JavaScript shell for wiki talk pages.",
	"homepage": "https://commons.wikimedia.org/wiki/User:Jack_who_built_the_house/Convenient_Discussions",
	"bugs": {
		"url": "https://phabricator.wikimedia.org/tag/convenient-discussions/"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jwbth/convenient-discussions.git"
	},
	"license": "MIT",
	"author": "Jack who built the house",
	"sideEffects": [
		"./src/loader/convenientDiscussions.loader.js",
		"./src/loader/convenientDiscussions.util.js",
		"./src/loader/convenientDiscussions.debug.js",
		"./src/shared/polyfills.js",
		"./src/worker/worker.js",
		"./src/worker/extendDomhandler.js",
		"./dist/convenientDiscussions-i18n/en.js"
	],
	"browser": "src/loader/startup.js",
	"scripts": {
		"build": "node build-wrapper.mjs",
		"build:dev": "node build-wrapper.mjs --mode development",
		"build:staging": "node build-wrapper.mjs --mode staging",
		"build:single": "node build-wrapper.mjs --mode single",
		"configs": "node buildConfigs.mjs",
		"deploy": "node --unhandled-rejections=strict deploy.mjs",
		"docs": "rimraf dist/docs && jsdoc --configure jsdoc/config.js --readme jsdoc/home.md",
		"format": "prettier --write .",
		"i18n": "node buildI18n.mjs",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"postinstall": "patch-package",
		"preview": "vite preview",
		"single": "node build-wrapper.mjs --mode single",
		"start": "vite",
		"test": "jest",
		"test:browser": "playwright test",
		"test:browser:auth": "playwright test test-wikipedia-auth.spec.js",
		"test:browser:headed": "playwright test --headed",
		"vite": "vite build"
	},
	"browserslist": [
		"> 1%"
	],
	"dependencies": {
		"date-fns": "^4.1.0",
		"date-fns-tz": "^3.2.0",
		"dayjs": "^1.11.18",
		"htmlparser2": "^10.0.0",
		"jest-environment-jsdom": "^30.1.2",
		"locutus": "^2.0.15",
		"lz-string": "^1.4.4",
		"mwn": "^3.0.1",
		"oojs": "^7.0.1"
	},
	"devDependencies": {
		"@babel/core": "^7.28.0",
		"@babel/eslint-parser": "^7.28.0",
		"@babel/plugin-transform-class-properties": "^7.27.1",
		"@babel/plugin-transform-class-static-block": "^7.28.3",
		"@babel/plugin-transform-logical-assignment-operators": "^7.27.1",
		"@babel/plugin-transform-nullish-coalescing-operator": "^7.27.1",
		"@babel/plugin-transform-numeric-separator": "^7.18.6",
		"@babel/plugin-transform-optional-catch-binding": "^7.27.1",
		"@babel/plugin-transform-optional-chaining": "^7.27.1",
		"@babel/plugin-transform-runtime": "^7.28.0",
		"@babel/plugin-transform-typescript": "^7.28.0",
		"@babel/preset-env": "^7.28.0",
		"@babel/runtime": "^7.28.2",
		"@eslint/js": "^9.32.0",
		"@playwright/test": "^1.57.0",
		"@stylistic/eslint-plugin": "^5.4.0",
		"@types/jest": "^30.0.0",
		"@types/jquery": "^3.5.32",
		"@types/jqueryui": "^1.12.23",
		"@types/oojs": "^7.0.7",
		"@types/oojs-ui": "^0.49.4",
		"@types/prompts": "^2.4.9",
		"ajv": "^6.12.6",
		"chalk": "^5.6.2",
		"codemirror": "^6.0.2",
		"core-js": "^3.45.1",
		"cross-env": "^7.0.3",
		"docdash": "^1.2.0",
		"dompurify": "^3.2.6",
		"eslint": "^9.39.1",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-es-x": "^9.1.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "^60.2.0",
		"eslint-plugin-no-one-time-vars": "^2.7.0",
		"eslint-plugin-unicorn": "^60.0.0",
		"eslint-plugin-unused-imports": "^4.3.0",
		"http-proxy-to-socks": "^1.1.2",
		"jest": "^30.1.3",
		"jsdoc": "^3.6.6",
		"jsdom": "^27.0.0",
		"json5": "^2.2.3",
		"less": "^4.4.2",
		"node-fetch": "^3.2.10",
		"patch-package": "^8.0.0",
		"playwright": "^1.57.0",
		"prettier": "^3.6.2",
		"prompts": "^2.4.2",
		"react": "^16.14.0",
		"react-dom": "^16.14.0",
		"rimraf": "^6.1.2",
		"terser": "^5.44.1",
		"types-mediawiki": "^1.10.1",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.44.0",
		"vite": "^7.2.2",
		"vite-plugin-banner": "^0.8.1",
		"yargs": "^18.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
