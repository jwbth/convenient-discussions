{
	"extends": "./jsconfig-base.json",
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"types": [
			// For typescript-eslint
			"prompts"
		]
	},

	// No subdirectories except for misc/
	"include": ["*", "misc/**/*"],
	"exclude": ["misc/convenientDiscussions-generateBasicConfig.js"],

	"typeAcquisition": {
		// Since we have a JS project, we need to prevent mismatches between the IDE and tsc
		// (https://www.typescriptlang.org/tsconfig/#type-acquisition)
		"enable": false
	}
}
