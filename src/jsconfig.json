{
	"extends": "../jsconfig-base.json",
	"compilerOptions": {
		"module": "esnext",
		"target": "es2022",
		"moduleResolution": "bundler",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"types": ["oojs", "oojs-ui", "jquery", "jqueryui"]
	},
	"include": [
		"**/*",
		"../config/**/*",
		"../misc/convenientDiscussions-generateBasicConfig.js",
